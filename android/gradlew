#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SDK_ROOT="${WATCHER_ANDROID_SDK_ROOT:-${ANDROID_SDK_ROOT:-${ANDROID_HOME:-}}}"

if [[ -n "${SDK_ROOT}" || ! -f "${ROOT_DIR}/local.properties" ]]; then
  "${ROOT_DIR}/scripts/prepare-local-properties.sh"
fi

GRADLE_BIN="$("${ROOT_DIR}/scripts/install-gradle.sh")"

cd "${ROOT_DIR}"
exec "${GRADLE_BIN}" "$@"
