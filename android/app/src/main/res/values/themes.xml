<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Watcher" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor" tools:targetApi="l">#0F172A</item>
        <item name="colorPrimary">#0F172A</item>
        <item name="colorPrimaryContainer">#DDE7FF</item>
        <item name="colorSecondary">#1D4ED8</item>
    </style>

    <style name="WatcherSettingsSection">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">#FFFFFF</item>
        <item name="android:orientation">vertical</item>
        <item name="android:padding">14dp</item>
    </style>

    <style name="WatcherSettingsTitle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">#0F172A</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="WatcherSettingsLabel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">#334155</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
