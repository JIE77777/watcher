<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/ccMimoSessionsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F1E9"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="CC MiMo Sessions"
        android:textColor="#0F172A"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/ccMimoSessionsStatusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Loading CC MiMo sessions…"
        android:textColor="#475569"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="#FFFFFF"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Driver: claude-mimo · mode=bypassPermissions · tools=default"
            android:textColor="#475569"
            android:textSize="13sp" />

        <Button
            android:id="@+id/ccMimoSessionsRefreshButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Refresh Sessions" />

        <Button
            android:id="@+id/ccMimoSessionsCreateButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="New CC Session" />
    </LinearLayout>

    <TextView
        android:id="@+id/ccMimoSessionsEmptyStateText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center_horizontal"
        android:text="No CC MiMo sessions yet."
        android:textColor="#64748B"
        android:textSize="14sp"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/ccMimoSessionsRecycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_weight="1" />
</LinearLayout>
