<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/boxRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F1E9"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/boxTitleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Box"
        android:textColor="#0F172A"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/boxStatusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="#475569"
        android:textSize="14sp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/boxSourceRecycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="18dp"
        android:layout_weight="1" />

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/boxTabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:tabIndicatorColor="#0F172A"
        app:tabSelectedTextColor="#0F172A"
        app:tabTextColor="#64748B"
        app:tabMode="scrollable" />

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/boxPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1" />

</LinearLayout>
