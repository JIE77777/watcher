<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/codexSessionsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F1E9"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Codex Threads"
        android:textColor="#0F172A"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/codexSessionsStatusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Loading Codex threads…"
        android:textColor="#475569"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="#FFFFFF"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/codexSessionsCapabilitiesText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Resume CLI: unknown"
            android:textColor="#475569"
            android:textSize="13sp" />

        <Button
            android:id="@+id/codexSessionsRefreshButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Refresh Threads" />

        <Button
            android:id="@+id/codexSessionsCreateButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="New Thread" />
    </LinearLayout>

    <TextView
        android:id="@+id/codexSessionsEmptyStateText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center_horizontal"
        android:text="No Codex threads yet. Start one from here or resume a desktop thread."
        android:textColor="#64748B"
        android:textSize="14sp"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/codexSessionsRecycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_weight="1" />

</LinearLayout>
