        {
          "field": "score",
          "label": "Score",
          "type": "score"
        },
        {
          "field": "price_input",
          "label": "Input $/M",
          "type": "number"
        }
      ],
      "sort": [
        {
          "field": "score",
          "direction": "desc"
        }
      ]
    }
